OMNI_BASE_URL=http://localhost:8882
OMNI_API_KEY=your-api-key
OMNI_INSTANCE_ID=your-instance-uuid

PORT=8080
LOG_LEVEL=INFO
LOG_FILE=logs/triage.log

SEND_VIA_OMNI=true
IGNORE_HISTORY_SYNC=true
MAX_MESSAGE_LENGTH=1000

GENIE_ENABLED=false
GENIE_TEAM=omni-whatsapp
GENIE_AGENT=team-lead
GENIE_REPLY_PREFIX=GENIE_JSON:
GENIE_RESPONSE_TIMEOUT_SECONDS=20

OPENAI_FALLBACK_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20
